function square(number: number) {
return number * number;
}

console.log(square(4)); 
console.log(square(9)); 

function minutesToSeconds(minutes: number) {
return minutes * 60;
}

console.log(minutesToSeconds(2));
console.log(minutesToSeconds(90));

function buildFullName(firstname: string, lastname: string, title: string) {
return title + " " + firstname + " " + lastname;
}

console.log(buildFullName("Ada", "Lovelace", "Ms.")); 

console.log(buildFullName("John", "Doe", "Dr.")); 

